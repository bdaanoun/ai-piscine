    "#Embedding 1\n",
    "\n",
    "import spacy\n",
    "\n",
    "nlp = spacy.load(\"en_core_web_sm\")\n",
    "\n",
    "doc = nlp(\"car\")\n",
    "vector = doc[0].vector\n",
    "\n",
    "print(vector.shape)\n",
    "\n",
    "s = sum(vector[:20])\n",
    "\n",
    "print(s.as_integer_ratio())"
   ]
  }
