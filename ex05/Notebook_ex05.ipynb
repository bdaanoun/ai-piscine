   "source": [
    "# Groupby Agg\n",
    "import pandas as pd\n",
    "\n",
    "df = pd.DataFrame({\n",
    "    \"value\": [20.45, 22.89, 32.12, 111.22, 33.22, 100, 99.99],\n",
    "    \"product\": [\"table\", \"chair\", \"chair\", \"mobile phone\", \"table\", \"mobile phone\", \"table\"]\n",
    "})\n",
    "df\n",
    "\n",
    "df.groupby(\"product\")[\"value\"].agg([\"min\", \"max\", \"mean\"])"
   ]
  }
