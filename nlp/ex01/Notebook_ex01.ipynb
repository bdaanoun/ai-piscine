    "# Lowercase\n",
    "import pandas as pd\n",
    "\n",
    "list_ = [\"This is my first NLP exercise\", \"omg!!!!!\"]\n",
    "series_data = pd.Series(list_, name='text')\n",
    "\n",
    "print(\"lowercase:\\n\", series_data.str.lower())\n",
    "\n",
    "print(\"\\nuppercase:\\n\", series_data.str.upper())"
   ]
  }
